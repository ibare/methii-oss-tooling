{
  "name": "methii-oss-tooling",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Shared developer tooling for Methii OSS packages",
  "license": "MIT",
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter=./packages/* build",
    "typecheck": "pnpm -r --filter=./packages/* typecheck",
    "test": "pnpm -r --filter=./packages/* test",
    "lint": "eslint packages",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@methii-oss/eslint-config": "workspace:*",
    "@types/node": "^25.7.0",
    "eslint": "^9.39.4",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
